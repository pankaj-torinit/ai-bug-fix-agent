PORT=3000

# OpenAI API key used by the LLM service for bug analysis and patch generation
OPENAI_API_KEY=your-openai-api-key

# GitHub personal access token with repo permissions (at least: repo, pull_request)
GITHUB_TOKEN=your-github-token

# Target GitHub repository in the form "owner/repo", e.g. "my-org/my-service"
GITHUB_REPO=owner/repo

# Name of the production branch in the target repository
GITHUB_PROD_BRANCH=prod

# Absolute path where the agent will clone the repository for each job
TEMP_REPO_PATH=/tmp/ai-agent-repo

# Redis connection URL used by BullMQ
REDIS_URL=redis://127.0.0.1:6379

# Optional: path to Docker socket (defaults to /var/run/docker.sock)
# DOCKER_SOCKET=/var/run/docker.sock

