PORT=3000

# OpenAI API key used by the LLM service for bug analysis and patch generation
LLM_API_KEY=your-openai-api-key

# GitHub personal access token with repo permissions (at least: repo, pull_request)
GITHUB_TOKEN=your-github-token

# Target GitHub repository in the form "owner/repo", e.g. "my-org/my-service"
GITHUB_REPO=owner/repo

# Name of the production branch in the target repository
GITHUB_PROD_BRANCH=prod

# Parent directory for per-job clone folders (each job gets a unique subdir under this path)
TEMP_REPO_PATH=/tmp/ai-agent-repo

# Redis connection URL used by BullMQ
REDIS_URL=redis://127.0.0.1:6379

# Optional: parallel bug-fix jobs (each uses a separate clone dir under TEMP_REPO_PATH)
# WORKER_CONCURRENCY=1

# W9: Sentry webhook — per-IP rate limit, event dedup, global per-minute cap (0 = disable that limit)
# WEBHOOK_RATE_LIMIT_MAX=100
# WEBHOOK_RATE_LIMIT_WINDOW_MS=900000
# SENTRY_EVENT_DEDUP_TTL_SEC=604800
# WEBHOOK_GLOBAL_MAX_PER_MINUTE=120
# Behind ngrok/reverse proxy, set so rate limits use real client IP:
# TRUST_PROXY=1

# Optional timeouts (ms, min 1000). W7: avoids hung worker on stuck LLM or tests.
# LLM_REQUEST_TIMEOUT_MS=600000
# SANDBOX_DOCKER_TIMEOUT_MS=900000
# SANDBOX_LOCAL_TIMEOUT_MS=900000

# Optional: LLM model name and base URL (defaults to OpenAI gpt-4.1-mini)
# LLM_MODEL=gpt-4.1-mini
# LLM_BASE_URL=https://api.openai.com/v1
# For NVIDIA NIM: LLM_MODEL=qwen/qwen3-coder-480b-a35b-instruct  LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional: patch reviewer (different model reduces self-consistency bias). Defaults match LLM_* / LLM_API_KEY.
# LLM_REVIEW_MODEL=gpt-4o
# LLM_REVIEW_BASE_URL=https://api.openai.com/v1
# LLM_REVIEW_API_KEY=

# Optional: path to Docker socket (defaults to /var/run/docker.sock)
# DOCKER_SOCKET=/var/run/docker.sock

# Optional: HMAC-SHA256 of raw request body; must match Sentry "Client Secret" for the webhook
# SENTRY_CLIENT_SECRET=
SENTRY_ALLOWED_PROJECTS=

NGROK_AUTHTOKEN=