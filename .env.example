PORT=3000

# OpenAI API key used by the LLM service for bug analysis and patch generation
LLM_API_KEY=your-openai-api-key

# GitHub personal access token with repo permissions (at least: repo, pull_request)
GITHUB_TOKEN=your-github-token

# Target GitHub repository in the form "owner/repo", e.g. "my-org/my-service"
GITHUB_REPO=owner/repo

# Name of the production branch in the target repository
GITHUB_PROD_BRANCH=prod

# Absolute path where the agent will clone the repository for each job
TEMP_REPO_PATH=/tmp/ai-agent-repo

# Redis connection URL used by BullMQ
REDIS_URL=redis://127.0.0.1:6379

# Optional: LLM model name and base URL (defaults to OpenAI gpt-4.1-mini)
# LLM_MODEL=gpt-4.1-mini
# LLM_BASE_URL=https://api.openai.com/v1
# For NVIDIA NIM: LLM_MODEL=qwen/qwen3-coder-480b-a35b-instruct  LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional: patch reviewer (different model reduces self-consistency bias). Defaults match LLM_* / LLM_API_KEY.
# LLM_REVIEW_MODEL=gpt-4o
# LLM_REVIEW_BASE_URL=https://api.openai.com/v1
# LLM_REVIEW_API_KEY=

# Optional: path to Docker socket (defaults to /var/run/docker.sock)
# DOCKER_SOCKET=/var/run/docker.sock

#SENTRY CLIENT KEY
SENTRY_CLIENT_KEY=
SENTRY_ALLOWED_PROJECTS=

NGROK_AUTHTOKEN=